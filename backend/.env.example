SPRING_PROFILES_ACTIVE=postgres
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/voltmart
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=replace-with-database-password
APP_JWT_SECRET=replace-with-a-long-random-secret-key
APP_JWT_EXPIRATION=86400000
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_STORE_FRONTEND_URL=http://localhost:3000
APP_GOOGLE_CLIENT_ID=your-google-client-id
APP_SEED_ADMIN_EMAIL=admin@voltmart.in
APP_SEED_ADMIN_PASSWORD=replace-with-a-strong-admin-password
APP_WHATSAPP_SUPPORT_NUMBER=919398546891
APP_WHATSAPP_ENABLED=false
APP_WHATSAPP_API_VERSION=v25.0
APP_WHATSAPP_PHONE_NUMBER_ID=your-meta-phone-number-id
APP_WHATSAPP_ACCESS_TOKEN=your-meta-permanent-access-token
APP_EMAIL_ENABLED=false
APP_EMAIL_PROVIDER=smtp
APP_EMAIL_FROM_ADDRESS=no-reply@yourdomain.com
APP_EMAIL_FROM_NAME=VoltMart
APP_EMAIL_API_KEY=your-email-api-key
APP_EMAIL_API_URL=https://api.brevo.com/v3/smtp/email
SPRING_MAIL_HOST=smtp.yourprovider.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-smtp-username
SPRING_MAIL_PASSWORD=your-smtp-password
